@using GamingZoneApp.ViewModels.Admin.User
@model IEnumerable<UserViewModel>

@{
    ViewData["Title"] = "User Management";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-people-fill"></i> @ViewData["Title"]</h1>
    </div>

    <div class="alert alert-info" role="alert">
        <p class="mb-0">Manage all registered users. You can view user accounts and their assigned roles from this panel.</p>
    </div>

    @if (!Model.Any())
    {
        <h2 class="mb-4">No users found...</h2>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th style="width: 250px;">Roles</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (UserViewModel user in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-primary">
                                <i class="bi bi-person-circle"></i> @user.Username
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                @if (user.Roles.Any())
                                {
                                    @foreach (string role in user.Roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-success" : "bg-secondary") me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No roles</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>
