@using GamingZoneApp.ViewModels.Admin.User
@model IEnumerable<UserViewModel>

@{
    ViewData["Title"] = "User Management";
    IEnumerable<string> allRoles = ViewBag.AllRoles as IEnumerable<string> ?? Enumerable.Empty<string>();
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-people-fill"></i> @ViewData["Title"]</h1>
    </div>

    <div class="alert alert-info" role="alert">
        <p class="mb-0">Manage all registered users. Assign or remove roles and delete user accounts from this panel.</p>
    </div>

    @if (!Model.Any())
    {
        <h2 class="mb-4">No users found...</h2>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Username</th>
                        <th>Email</th>
                        <th style="width: 200px;">Current Roles</th>
                        <th style="width: 380px;">Manage Roles</th>
                        <th class="text-center" style="width: 120px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (UserViewModel user in Model)
                    {
                        string dropdownId = $"roleSelect_{user.Id.ToString("N")}";
                        <tr>
                            <td class="fw-semibold text-primary">
                                <i class="bi bi-person-circle"></i> @user.Username
                            </td>
                            <td class="text-muted">@user.Email</td>
                            <td>
                                @if (user.Roles.Any())
                                {
                                    @foreach (string role in user.Roles.OrderBy(r => r))
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-success" : role == "Moderator" ? "bg-primary" : "bg-secondary") me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No roles</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <select id="@dropdownId" class="form-select form-select-sm">
                                        <option value="">-- Select --</option>
                                        @foreach (string role in allRoles.OrderBy(r => r))
                                        {
                                            <option value="@role">@role</option>
                                        }
                                    </select>
                                    <form asp-area="Admin" asp-controller="UserManagement" asp-action="AssignRole" method="post">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="selectedRole" value="" data-source="@dropdownId" />
                                        <button type="submit" class="btn btn-success btn-sm">
                                            <i class="bi bi-plus-circle"></i> Assign
                                        </button>
                                    </form>
                                    <form asp-area="Admin" asp-controller="UserManagement" asp-action="RemoveRole" method="post">
                                        <input type="hidden" name="selectedRole" value="" data-source="@dropdownId" />
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <button type="submit" class="btn btn-warning btn-sm">
                                            <i class="bi bi-dash-circle"></i> Remove
                                        </button>
                                    </form>
                                </div>
                            </td>
                            <td class="text-center">
                                <form asp-area="Admin" asp-controller="UserManagement" asp-action="DeleteUser" method="get">
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('form').forEach(function (form) {
            form.addEventListener('submit', function () {
                var hiddenInput = form.querySelector('input[data-source]');
                if (hiddenInput) {
                    var selectId = hiddenInput.getAttribute('data-source');
                    var select = document.getElementById(selectId);
                    if (select) {
                        hiddenInput.value = select.value;
                    }
                }
            });
        });
    </script>
}
