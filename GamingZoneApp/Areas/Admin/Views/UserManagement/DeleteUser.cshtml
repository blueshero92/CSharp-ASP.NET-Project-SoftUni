@using GamingZoneApp.ViewModels.Admin.User
@model DeleteUserViewModel

@{
    ViewData["Title"] = "Delete User";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-6 offset-lg-3">

            <div class="border rounded p-4 shadow-sm">
                <h2 class="text-danger mb-4">
                    <i class="bi bi-exclamation-triangle-fill"></i> Confirm User Deletion
                </h2>

                <p class="fs-5">You are about to permanently remove this account from the system:</p>

                <p class="fs-4 fw-bold text-white mb-4">
                    <i class="bi bi-person-circle"></i> @Model.Username                   
                </p>
                <p class="fs-4 fw-bold text-white mb-4">
                    <i class="bi bi-envelope"></i> @Model.Email
                </p>

                <div class="bg-danger rounded p-3 mb-4">
                    <p class="mb-0 text-black">
                        <i class="bi bi-info-circle"></i>
                        <strong>This will permanently delete the user account, all role assignments, and any associated data.
                                This action cannot be undone</strong>.
                    </p>
                </div>

                <form asp-area="Admin" asp-controller="UserManagement" asp-action="DeleteUser" method="post">
                    <div class="d-flex gap-2 justify-content-end">
                        <a asp-area="Admin" asp-controller="UserManagement" asp-action="Index"
                           class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="bi bi-person-x-fill"></i> Delete User
                        </button>
                    </div>
                </form>
            </div>

        </div>
    </div>
</div>
