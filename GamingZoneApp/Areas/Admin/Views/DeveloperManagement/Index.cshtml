@using GamingZoneApp.ViewModels.Developer
@model IEnumerable<AllDevelopersViewModel>

@{
    ViewData["Title"] = "Developer Management";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-person-fill-gear"></i> @ViewData["Title"]</h1>
        <a asp-area="Admin" asp-controller="DeveloperManagement" asp-action="AddDeveloper" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add Developer
        </a>
    </div>

    <div class="alert alert-info" role="alert">
        <p class="mb-0">Manage all game developers. You can edit or delete developer profiles from this panel.</p>
    </div>

    @if (!Model.Any())
    {
        <h2 class="mb-4">No developers found...</h2>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 60px;"></th>
                        <th>Name</th>
                        <th>Description</th>
                        <th class="text-center" style="width: 140px;">Games Developed</th>
                        <th class="text-center" style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AllDevelopersViewModel developer in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(developer.ImageUrl))
                                {
                                    <img src="@developer.ImageUrl" alt="@developer.Name"
                                         class="rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                                }
                                else
                                {
                                    <i class="bi bi-image text-muted fs-3"></i>
                                }
                            </td>
                            <td class="fw-semibold text-primary">@developer.Name</td>
                            <td class="text-muted">
                                @if (!string.IsNullOrEmpty(developer.Description))
                                {
                                    @(developer.Description.Length > 80
                                        ? developer.Description.Substring(0, 80) + "..."
                                        : developer.Description)
                                }
                                else
                                {
                                    <em>No description available.</em>
                                }
                            </td>
                            <td class="text-center">
                                <span class="badge bg-info fs-6">@developer.GamesDeveloped</span>
                            </td>
                            <td class="text-center">
                                <a asp-area="Admin" asp-controller="DeveloperManagement" asp-action="EditDeveloper" asp-route-id="@developer.Id"
                                   class="btn btn-warning btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <a asp-area="Admin" asp-controller="DeveloperManagement" asp-action="DeleteDeveloper" asp-route-id="@developer.Id"
                                   class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>
