@using GamingZoneApp.ViewModels.Game
@model IEnumerable<AllGamesViewModel>

@{
    ViewData["Title"] = "Game Management";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0"><i class="bi bi-controller"></i> @ViewData["Title"]</h1>
        <a asp-area="" asp-controller="Games" asp-action="AddGame" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Add Game
        </a>
    </div>

    <div class="alert alert-info" role="alert">
        <p class="mb-0">Manage all games in the catalog. You can edit or permanently delete any game from this panel.</p>
    </div>

    @if (!Model.Any())
    {
        <h2 class="mb-4">No games found...</h2>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 60px;"></th>
                        <th>Title</th>
                        <th>Genre</th>
                        <th>Developer</th>
                        <th class="text-end" style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (AllGamesViewModel game in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(game.ImageUrl))
                                {
                                    <img src="@game.ImageUrl" alt="@game.Title"
                                         class="rounded" style="width: 50px; height: 50px; object-fit: cover;" />
                                }
                                else
                                {
                                    <i class="bi bi-image text-muted fs-3"></i>
                                }
                            </td>
                            <td class="fw-semibold text-primary">@game.Title</td>
                            <td class="text-info fw-semibold">@game.Genre</td>
                            <td class="text-info fw-semibold">@game.Developer</td>
                            <td class="text-end">
                                <a asp-area="Admin" asp-controller="GameManagement" asp-action="Edit" asp-route-id="@game.Id"
                                   class="btn btn-warning btn-sm me-1">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <a asp-area="" asp-controller="Games" asp-action="DeleteGame" asp-route-id="@game.Id"
                                   class="btn btn-danger btn-sm">
                                    <i class="bi bi-trash"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="mt-3">
        <a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>
