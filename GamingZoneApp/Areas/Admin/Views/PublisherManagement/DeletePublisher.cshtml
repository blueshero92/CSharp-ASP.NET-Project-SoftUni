@using GamingZoneApp.ViewModels.Admin.Publisher
@model DeletePublisherViewModel

@{
    ViewData["Title"] = "Delete Publisher";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-6 offset-lg-3">
            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0"><i class="bi bi-trash"></i> @ViewData["Title"]</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning" role="alert">
                        <h5 class="alert-heading">Are you sure?</h5>
                        <p>You are about to permanently delete the following publisher:</p>
                        <hr>
                        <p class="mb-0"><strong>@Model.Name</strong></p>
                    </div>

                    <p class="text-muted">This action cannot be undone.</p>

                    <form asp-area="Admin" asp-controller="PublisherManagement" asp-action="DeletePublisher" method="post">
                        <input type="hidden" asp-for="Name" />
                        <div class="d-flex gap-2 justify-content-end">
                            <a asp-area="Admin" asp-controller="PublisherManagement" asp-action="Index"
                               class="btn btn-secondary">
                                Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>