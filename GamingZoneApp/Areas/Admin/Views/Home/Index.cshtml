@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <div class="row align-items-center mb-5">
        <div class="col-lg-8">
            <h1 class="display-4 fw-bold"><i class="bi bi-speedometer2"></i> Admin Dashboard</h1>
            <p class="lead text-muted">
                Manage users, games, developers and publishers from a single place.
            </p>
        </div>
    </div>

    <div class="row g-4">

        <!-- User Management -->
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-people-fill display-4 text-primary mb-3"></i>
                    <h5 class="card-title fw-semibold">User Management</h5>
                    <p class="text-muted mb-4">View, edit and manage registered users and their roles.</p>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-primary w-100">
                        <i class="bi bi-arrow-right-circle"></i> Manage Users
                    </a>
                </div>
            </div>
        </div>

        <!-- Game Management -->
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-controller display-4 text-success mb-3"></i>
                    <h5 class="card-title fw-semibold">Game Management</h5>
                    <p class="text-muted mb-4">Add, edit, delete and review all games in the catalog.</p>
                    <a asp-area="Admin" asp-controller="GameManagement" asp-action="Index" class="btn btn-success w-100">
                        <i class="bi bi-arrow-right-circle"></i> Manage Games
                    </a>
                </div>
            </div>
        </div>

        <!-- Developer Management -->
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-person-fill-gear display-4 text-warning mb-3"></i>
                    <h5 class="card-title fw-semibold">Developer Management</h5>
                    <p class="text-muted mb-4">Create, update and remove game developer profiles.</p>
                    <a asp-area="Admin" asp-controller="Developers" asp-action="Index" class="btn btn-warning w-100">
                        <i class="bi bi-arrow-right-circle"></i> Manage Developers
                    </a>
                </div>
            </div>
        </div>

        <!-- Publisher Management -->
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    <i class="bi bi-person-lines-fill display-4 text-danger mb-3"></i>
                    <h5 class="card-title fw-semibold">Publisher Management</h5>
                    <p class="text-muted mb-4">Create, update and remove game publisher profiles.</p>
                    <a asp-area="Admin" asp-controller="Publishers" asp-action="Index" class="btn btn-danger w-100">
                        <i class="bi bi-arrow-right-circle"></i> Manage Publishers
                    </a>
                </div>
            </div>
        </div>

    </div>

    <!-- Quick Links -->
    <section class="py-5 mt-4">
        <h4 class="fw-semibold mb-3"><i class="bi bi-lightning-fill"></i> Quick Actions</h4>
        <div class="row g-3">
            <div class="col-md-4">
                <div class="border rounded p-4 h-100">
                    <h5 class="fw-semibold mb-2"><i class="bi bi-plus-circle text-success"></i> Add New Game</h5>
                    <p class="text-muted mb-3">Quickly add a new game to the catalog.</p>
                    <a asp-area="" asp-controller="Games" asp-action="AddGame" class="btn btn-outline-success btn-sm">
                        <i class="bi bi-plus"></i> Add Game
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-4 h-100">
                    <h5 class="fw-semibold mb-2"><i class="bi bi-list-ul text-primary"></i> Browse All Games</h5>
                    <p class="text-muted mb-3">View the full public game catalog.</p>
                    <a asp-area="" asp-controller="Games" asp-action="Index" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-eye"></i> View Games
                    </a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-4 h-100">
                    <h5 class="fw-semibold mb-2"><i class="bi bi-house text-secondary"></i> Back to Site</h5>
                    <p class="text-muted mb-3">Return to the public-facing home page.</p>
                    <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-arrow-left"></i> Home Page
                    </a>
                </div>
            </div>
        </div>
    </section>
</div>
