@using GamingZoneApp.ViewModels.Game
@model GameViewModel

@{
	ViewData["Title"] = Model?.Title ?? "Game Details";
}

<div class="container mt-5">
	@if (Model != null)
	{
		<div class="row">
			<div class="col-lg-8 offset-lg-2">
				<!-- Game Header -->
				<div class="mb-4">
					<a asp-action="Index" asp-controller="Games" class="btn btn-secondary btn-sm">
						<i class="bi bi-arrow-left"></i> Go to All Games
					</a>
				</div>

				<!-- Game Card -->
				<div class="card shadow-lg mb-4">
					<!-- Game Image -->
					<img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title" style="max-height: 400px; object-fit: cover;">

					<div class="card-body">
						<!-- Title -->
						<h1 class="card-title mb-3">@Model.Title</h1>

						<!-- Genre and Rating -->
						<div class="row mb-3">
							<div class="col-md-6">
								<p class="mb-1"><strong>Genre:</strong></p>
								<span class="badge bg-primary">@Model.Genre.ToString()</span>
							</div>
							<div class="col-md-6">
								<p class="mb-1"><strong>Rating:</strong></p>
								<div class="d-flex align-items-center gap-2">
									<span class="h5 mb-0">@Model.Rating.ToString("F1")</span>
									<span class="text-warning">
										@for (int i = 0; i < 5; i++)
										{
											@if (i < (int)Model.Rating)
											{
												<i class="fas fa-star"></i>
											}
											else
											{
												<i class="far fa-star"></i>
											}
										}
									</span>
								</div>
							</div>
						</div>

						<!-- Release Date -->
						<div class="mb-3">
							<p class="mb-1"><strong>Release Date:</strong></p>
							<p class="text-muted">@Model.ReleaseDate</p>
						</div>

						<!-- Description -->
						<div class="mb-4">
							<h5 class="mb-2">About</h5>
							<p class="text-justify">@Model.Description</p>
						</div>

						<!-- Developer and Publisher Info -->
						<div class="row g-3">
							<!-- Developer Info -->
							<div class="col-md-6">
								<div class="card border-light bg-light h-100">
									<div class="card-body">
										<h6 class="card-title mb-3">Developer</h6>
										<div class="d-flex flex-column align-items-center text-center">
											<img src="@Model.DeveloperLogoUrl" alt="@Model.Developer" class="rounded mb-3" style="width: 80px; height: 80px; object-fit: cover;">
											<h6 class="mb-0">@Model.Developer</h6>
										</div>
									</div>
								</div>
							</div>

							<!-- Publisher Info -->
							<div class="col-md-6">
								<div class="card border-light bg-light h-100">
									<div class="card-body">
										<h6 class="card-title mb-3">Publisher</h6>
										<div class="d-flex flex-column align-items-center text-center">
											<img src="@Model.PublisherLogoUrl" alt="@Model.Publisher" class="rounded mb-3" style="width: 80px; height: 80px; object-fit: cover;">
											<h6 class="mb-0">@Model.Publisher</h6>
										</div>
									</div>
								</div>
							</div>
						</div>

						<!-- Action Buttons -->
						<div class="d-flex flex-column gap-2 mt-4 w-100">
							@if (User?.Identity?.IsAuthenticated == true)
							{
								<form asp-controller="Games" asp-action="AddToFavorites" method="post" class="m-0">
									<input type="hidden" name="gameId" value="@Model.Id" />
									<button type="submit" class="btn btn-success w-100">
										<i class="bi bi-plus-circle"></i> Add to Favorites
									</button>
								</form>
								<form asp-controller="Games" asp-action="RemoveFromFavorites" method="post" class="m-0">
									<input type="hidden" name="gameId" value="@Model.Id" />
									<button type="submit" class="btn btn-primary w-100">
										<i class="bi bi-x-circle"></i> Remove from Favorites
									</button>
								</form>

								<a asp-action="EditGame" asp-controller="Games" asp-route-id="@Model.Id" class="btn btn-warning w-100">
									<i class="bi bi-pencil-square"></i> Edit
								</a>
								<a asp-action="DeleteGame" asp-controller="Games" asp-route-id="@Model.Id" class="btn btn-danger w-100">
									<i class="bi bi-trash"></i> Delete
								</a>
							}
							else
							{
								<a asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" class="btn btn-primary btn-lg">
									Log In
								</a>
								<a asp-area="Identity" asp-page="/Account/Register" asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)" class="btn btn-secondary btn-lg">
									Register as a new User
								</a>
							}
						</div>
					</div>
				</div>
			</div>
		</div>
	}
	else
	{
		<div class="alert alert-warning" role="alert">
			<h4 class="alert-heading">Game Not Found</h4>
			<p>The requested game could not be found. Please try again.</p>
			<hr>
			<a asp-action="Index" asp-controller="Games" class="btn btn-primary btn-sm">Back to Games</a>
		</div>
	}
</div>
