@using GamingZoneApp.ViewModels.Game
@using GamingZoneApp.GCommon.Pagination

@model PaginatedList<AllGamesViewModel>

@{
	ViewData["Title"] = "All Games";
}

<div class="container mt-5">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h1 class="mb-0">@ViewData["Title"]</h1>
		<a asp-action="AddGame" class="btn btn-success">
			<i class="bi bi-plus-circle"></i> Add Game
		</a>
	</div>

	<div class="alert alert-info" role="alert">
		<p>Explore our collection of amazing video games. Discover detailed information about each title including genre, developer, and more.</p>
		<hr>
		<p class="mb-0">Browse through our curated selection of games from various genres and developers around the world.</p>
	</div>

	<form asp-action="Index" method="get" class="mb-4">
		<div class="input-group">
			<input type="text" name="searchQuery" class="form-control" placeholder="Search by title, genre, developer, or publisher..."
				   value="@ViewData["SearchQuery"]" />
			<button type="submit" class="btn btn-primary" style="width: 120px;">
				<i class="bi bi-search"></i> Search
			</button>
			@if (!string.IsNullOrWhiteSpace(ViewData["SearchQuery"]?.ToString()))
			{

				<a asp-action="Index" type="button" class="btn btn-outline-danger d-flex align-items-center justify-content-center" style="width: 120px;">
					<i class="bi bi-x-circle"></i>&nbsp;Clear
				</a>

			}
		</div>
	</form>

	<partial name="_AllGamesPartial" model="@Model" />

	<p></p>

	<partial name="_PaginationPartial" model="@Model" />
</div>

