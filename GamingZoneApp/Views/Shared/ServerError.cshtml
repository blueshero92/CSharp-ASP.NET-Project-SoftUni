@{
    ViewData["Title"] = "Server Error";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <i class="bi bi-emoji-frown-fill display-1 text-danger"></i>
                    <h1 class="display-1 fw-bold text-danger">500</h1>
                    <h2 class="mb-3 text-danger">Server Error!</h2>
                    <p class="text-muted mb-4">
                        Something went wrong on our end. Please try again later.
                    </p>
                    <div class="d-flex flex-column gap-2">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                            <i class="bi bi-arrow-left"></i> Back to Home
                        </a>
                        <a asp-controller="Games" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="bi bi-list"></i> Browse Games
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
