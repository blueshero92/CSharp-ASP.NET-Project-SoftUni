@{
    ViewData["Title"] = "Bad Request";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 text-center">
            <div class="card shadow-lg border-0">
                <div class="card-body p-5">
                    <h1 class="display-1 fw-bold text-warning">400</h1>
                    <h2 class="mb-3">Bad Request</h2>
                    <p class="text-muted mb-4">
                        The request could not be understood by the application or was missing required parameters.
                        Please check the URL and try again.
                    </p>
                    <div class="d-flex flex-column gap-2">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                            <i class="fas fa-home me-1"></i> Back to Home
                        </a>
                        <a asp-controller="Games" asp-action="Index" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-gamepad me-1"></i> Browse Games
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
